# Google Maps Platform API key (for satellite tile downloads)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Maps Static API" in your Google Cloud project
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# HuggingFace token (for SAM3 model weight downloads — used in Colab)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Copernicus CDS API key (optional — only needed if BARRA2 is inaccessible)
# Get one at: https://cds.climate.copernicus.eu/user/register
CDS_API_KEY=your_cds_api_key_here
