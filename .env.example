# Google Maps Platform API key (for satellite tile downloads)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Maps Static API" in your Google Cloud project
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Google Gemini API key (for roof segmentation — replaces SAM/Colab)
# Get a FREE key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min (enough for testing; paid tier is much faster)
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace token (optional — only needed if using SAM on Colab)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Google Sheets ticket tracker (QA bot)
# Sheet ID from the URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_sheet_id_here
# Path to your GWS OAuth2 credential file (client_id + refresh_token)
GWS_CREDS_FILE=~/.config/gws/uni-email.json

# Copernicus CDS API key (optional — only needed if BARRA2 is inaccessible)
# Get one at: https://cds.climate.copernicus.eu/user/register
CDS_API_KEY=your_cds_api_key_here
